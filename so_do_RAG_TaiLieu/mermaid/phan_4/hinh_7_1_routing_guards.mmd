flowchart TB
    URL["URL người dùng truy cập"]
    ROUTER["<b>App.jsx · React Router</b>"]

    PATH{"path?"}

    LOGIN["<b>/login</b> · LoginPage (public)<br/>nếu đã login → redirect /"]

    PROTECT["<b>ProtectedRoute</b> · kiểm tra accessToken && user<br/>chưa login → redirect /login"]

    CHAT["<b>/ → ChatPage</b>"]

    ADMIN_R["<b>AdminRoute</b> · ProtectedRoute + hasManagerAccess(user.role)<br/>rank &lt; manager → redirect /"]

    ADMIN_P["<b>/admin → AdminPage</b> (4 tabs)"]

    REDIRECT[("/* → redirect /")]

    URL --> ROUTER --> PATH
    PATH -->|"/login"| LOGIN
    PATH -->|"/"| PROTECT --> CHAT
    PATH -->|"/admin"| ADMIN_R --> ADMIN_P
    PATH -->|"others"| REDIRECT

    NOTE["<b>RBAC</b> · ROLE_RANK = {user:1, manager:2, admin:3, superadmin:4}<br/>hasManagerAccess(role) → rank ≥ 2 · hasAdminAccess(role) → rank ≥ 3"]

    NOTE -.- ADMIN_R

