    CRON --> DUMP --> SP
    SP -->|"STORAGE_PROVIDER=gcs"| GCS
    SP -.->|"=minio (on-prem)"| MINIO
    RTEST --> EPH
    GCS --> EPH
    EPH --> VERIFY --> REPORT

