flowchart TB
    CRON["cron 2h sáng<br/>08_backup_to_gcs.sh"]
    DUMP["mongodump + tar<br/>ChromaDB · SQLite"]
    SP["<b>storage_provider.sh</b><br/>(router)"]
    GCS["GCS bucket<br/>giữ 90 ngày"]
    MINIO["MinIO<br/>(on-prem · stub)"]
    RTEST["cron tháng<br/>09_restore_test.sh"]
