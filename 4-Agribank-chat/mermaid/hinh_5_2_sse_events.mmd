flowchart TB
    SSE["📡 sseClient.streamChat() · fetch().body.getReader()<br/>buffer split('\\n\\n') → parse 'data: {...}'"]

    EV{"event.type ?"}

    META["<b>onMeta(event)</b><br/>· setCurrentSessionId(event.session_id)<br/>· registerSession(id, question)<br/>· sources = event.sources<br/>· thay typingMsg bằng empty bot msg"]

    TOKEN["<b>onToken(content)</b><br/>· accContent += content<br/>· setMessages: cập nhật content message cuối"]

    DONE["<b>onDone(event)</b><br/>· finalSources = event.effective_sources ?? acc_sources<br/>· gán generation_time_ms<br/>· setIsStreaming(false)"]

    FOLLOW["<b>onFollowups(items)</b><br/>· gán items vào last message · render chip buttons"]

    ERR["<b>onError(detail)</b><br/>· setError(detail)<br/>· filter typingMsg ra khỏi messages<br/>· setIsStreaming(false)"]

    UI[/"<b>MessageList re-render</b><br/>StreamingDot trong khi typing<br/>Markdown content qua react-markdown<br/>SourceCard + FollowupChips ở message cuối"\]

    SSE --> EV
    EV -->|"meta"| META --> UI
    EV -->|"token"| TOKEN --> UI
    EV -->|"done"| DONE --> UI
    EV -->|"followups"| FOLLOW --> UI
    EV -->|"error"| ERR --> UI

