flowchart TB
    subgraph AUTH["🔐 authStore (sessionStorage persist)"]
        direction TB
        AS_STATE["State · user · accessToken · refreshToken · isLoading"]
        AS_ACT["Actions · login · setTokens · updateUser · logout · setLoading"]
        AS_SEL["Selector hooks · useUserRole · useIsAdmin · useIsSuperAdmin · useCanAccessAdminPanel"]
        AS_HELP["Pure helper · hasMinimumRole(role, minRole) → boolean"]
    end

    subgraph SESS["🗂️ useSessionStore (memory only)"]
        direction TB
        SE_STATE["State · sessions[] · currentSessionId · needsHistoryRestore"]
        SE_ACT["Actions · setCurrentSessionId · registerSession (upsert) · bulkRegisterSessions · removeSession · clearAll"]
    end

    subgraph TOAST["🔔 toastStore"]
        direction TB
        TS_STATE["State · toasts[]"]
        TS_ACT["Actions · addToast (auto-dismiss 4s) · removeToast"]
    end

    NOTE["<b>sessionStorage</b> · key 'agribank_auth' · tự xóa khi đóng tab — phù hợp internal tool. Logout gọi useSessionStore.clearAll() để tránh sessions cũ hiện sau khi user khác login."]

